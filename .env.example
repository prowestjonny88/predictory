# Database
# Neon Postgres (production) or SQLite path (local dev fallback)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/bakewise?sslmode=require
# SQLite fallback for offline dev:
# DATABASE_URL=sqlite:///./bakewise.db

# Redis (Upstash)
REDIS_URL=redis://default:password@xxxx.upstash.io:6379

# LLM / AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Explicit LiteLLM override. If set, this wins.
LITELLM_MODEL=

# Gemini via Google AI Studio.
# If GEMINI_API_KEY or GOOGLE_API_KEY is set and LITELLM_MODEL is blank,
# the copilot routes default to Gemini.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini/gemini-2.5-flash
# Optional override:
# GEMINI_API_BASE=https://generativelanguage.googleapis.com

# Gemini via Vertex AI.
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1

# App
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
